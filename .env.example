# ════════════════════════════════════════════════════════
# CNR Platform — Environment Variables
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to git.
# ════════════════════════════════════════════════════════

# ── Node ────────────────────────────────────────────────
NODE_ENV=development

# ── Database (MariaDB) ──────────────────────────────────
DB_ROOT_PASSWORD=cnr_root_secret
DB_NAME=cnr_platform
DB_USER=cnr_user
DB_PASSWORD=cnr_pass

# ── Prisma (used locally, outside Docker) ───────────────
DATABASE_URL=mysql://cnr_user:cnr_pass@localhost:3306/cnr_platform

# ── AWS S3 ──────────────────────────────────────────────
AWS_REGION=ap-southeast-1
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here
AWS_S3_BUCKET=cnr-documents

# ── Next.js ─────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:4000
